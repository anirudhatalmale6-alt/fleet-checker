default_platform(:ios)

platform :ios do
  desc "Build and upload to App Store Connect"
  lane :release do
    # Expand ~ in the key path
    key_path = File.expand_path(ENV["APP_STORE_CONNECT_KEY_PATH"])
    UI.message("Using API key at: #{key_path}")
    UI.message("Key file exists: #{File.exist?(key_path)}")
    UI.message("Key file size: #{File.size(key_path)} bytes") if File.exist?(key_path)

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: key_path,
      duration: 1200,
      in_house: false
    )

    # Create a temporary keychain for CI
    keychain_name = "build_keychain"
    keychain_password = "ci_build_password_2026"

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Fetch or create an iOS Distribution certificate
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    cert(
      api_key: api_key,
      keychain_path: keychain_path,
      keychain_password: keychain_password,
      development: false
    )

    # Fetch or create an App Store provisioning profile
    sigh(
      api_key: api_key,
      app_identifier: "com.fleetchecker.fleetchecker",
      force: true,
      adhoc: false
    )

    # Get profile info from lane context
    profile_name = lane_context[SharedValues::SIGH_NAME]
    profile_uuid = lane_context[SharedValues::SIGH_UUID]
    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    UI.message("Profile name: #{profile_name}")
    UI.message("Profile UUID: #{profile_uuid}")
    UI.message("Profile path: #{profile_path}")

    # Update Xcode project to use manual signing with fetched profile
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: "V9679HX2M6",
      bundle_identifier: "com.fleetchecker.fleetchecker",
      profile_name: profile_name,
      code_sign_identity: "iPhone Distribution"
    )

    # Build the archive and export IPA
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "FleetChecker.ipa",
      clean: false,
      xcargs: "PROVISIONING_PROFILE_SPECIFIER='#{profile_name}' OTHER_CODE_SIGN_FLAGS='--keychain #{keychain_path}'",
      export_options: {
        teamID: "V9679HX2M6",
        signingStyle: "manual",
        provisioningProfiles: {
          "com.fleetchecker.fleetchecker" => profile_name
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
